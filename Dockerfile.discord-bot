FROM node:20-slim

WORKDIR /app

# Copy package files first for better layer caching
COPY letta-discord-bot-example/package*.json ./

# Install production dependencies only
RUN npm ci --omit=dev

# Copy source code
COPY letta-discord-bot-example/ .

# Build TypeScript to JavaScript
RUN npm run build

# Run the bot
CMD ["npm", "start"]
