# ── LLM API Keys (add whichever you're using) ─────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ── Letta Server ───────────────────────────────────────────────────
# Used by the discord bot to reach the letta server.
# In Docker Compose this is overridden to http://letta-server:8283
# For running the bot locally (outside Docker), keep this as localhost:
LETTA_BASE_URL=http://localhost:8283

# Optional: password-protect your Letta server
# SECURE=true
# LETTA_SERVER_PASSWORD=your_password_here

# ── Discord Bot ────────────────────────────────────────────────────
# From Discord Developer Portal → Your App → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# From Discord Developer Portal → Your App → General Information
DISCORD_APPLICATION_ID=your_discord_application_id_here
DISCORD_PUBLIC_KEY=your_discord_public_key_here

# Your Personal Assistant agent ID (from running create_agents.py)
LETTA_AGENT_ID=agent-xxxx-xxxx-xxxx-xxxx

# How many recent messages to include as context for the agent
LETTA_CONTEXT_MESSAGE_COUNT=10

# Set to true to only respond when @mentioned (recommended for servers)
RESPOND_TO_MENTIONS=true
