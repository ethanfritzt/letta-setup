# ── LLM API Keys (add whichever you're using) ─────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ── Letta Server ───────────────────────────────────────────────────
# Used by the discord bot to reach the letta server.
# In Docker Compose this is overridden to http://letta-server:8283
# For running the bot locally (outside Docker), keep this as localhost:
LETTA_BASE_URL=http://localhost:8283

# Optional: password-protect your Letta server
# SECURE=true
# LETTA_SERVER_PASSWORD=your_password_here

# ── LLM Model ──────────────────────────────────────────────────────
# Global default model (used if no per-agent override is set)
LETTA_MODEL=anthropic/claude-sonnet-4-6

# Per-agent model overrides (optional — uncomment and set to override)
# LETTA_MODEL_PA=anthropic/claude-sonnet-4-6
# LETTA_MODEL_RESEARCH=anthropic/claude-haiku-4-5
# LETTA_MODEL_TASK=anthropic/claude-haiku-4-5
# LETTA_MODEL_CODING=anthropic/claude-sonnet-4-6
# LETTA_MODEL_HOMEASSISTANT=anthropic/claude-haiku-4-5

# ── GitHub Access ──────────────────────────────────────────────────
# Personal Access Token for GitHub operations.
# Used by: Task Agent (GitHub MCP server), Coding Agent (git clone, gh CLI)
# Create at: https://github.com/settings/tokens
# Required scopes: repo (for private repo access)
# GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── MCP Servers (optional - skip to disable) ───────────────────────

# Home Assistant MCP Server (ha-mcp)
# URL of your ha-mcp server (from HA add-on or external)
# e.g., http://homeassistant.local:8123/api/mcp or your add-on URL
# HOMEASSISTANT_MCP_URL=http://homeassistant.local:8123/api/mcp
# Long-lived access token from Home Assistant
# HOMEASSISTANT_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# Document Store (Filesystem MCP)
# Host path to the document store directory, mounted into the Letta container at /documents.
# This should point to the same directory your SilverBullet instance serves (e.g., ./space).
# Defaults to ./space if not set.
# DOCUMENT_STORE_PATH=./space

# ── Coding Sandbox Service ─────────────────────────────────────────
# URL where the coding sandbox service is running.
# In Docker Compose this is set automatically to http://coding-sandbox:3002
# SANDBOX_SERVICE_URL=http://localhost:3002

# Timeout for coding tasks in milliseconds (default: 10 minutes)
# TASK_TIMEOUT_MS=600000

# ── Discord Bot ────────────────────────────────────────────────────
# From Discord Developer Portal → Your App → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# From Discord Developer Portal → Your App → General Information
# Note: The upstream letta-discord-bot-example uses APP_ID / PUBLIC_KEY in its
# .env.template, but neither variable is used at runtime by the bot code.
# These are kept here for reference if you set up Discord HTTP interactions.
DISCORD_APPLICATION_ID=your_discord_application_id_here
DISCORD_PUBLIC_KEY=your_discord_public_key_here

# Your Personal Assistant agent ID (from running create_all.py)
LETTA_AGENT_ID=agent-xxxx-xxxx-xxxx-xxxx

# How many recent messages to include as context for the agent
LETTA_CONTEXT_MESSAGE_COUNT=10

# Set to true to only respond when @mentioned (recommended for servers)
RESPOND_TO_MENTIONS=true
