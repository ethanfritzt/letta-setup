# ── LLM API Keys (add whichever you're using) ─────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ── Letta Server ───────────────────────────────────────────────────
# Used by the discord bot to reach the letta server.
# In Docker Compose this is overridden to http://letta-server:8283
# For running the bot locally (outside Docker), keep this as localhost:
LETTA_BASE_URL=http://localhost:8283

# Optional: password-protect your Letta server
# SECURE=true
# LETTA_SERVER_PASSWORD=your_password_here

# ── LLM Model ──────────────────────────────────────────────────────
# Global default model (used if no per-agent override is set)
LETTA_MODEL=anthropic/claude-sonnet-4-6

# Per-agent model overrides (optional — uncomment and set to override)
# LETTA_MODEL_PA=anthropic/claude-sonnet-4-6
# LETTA_MODEL_RESEARCH=anthropic/claude-haiku-4-5
# LETTA_MODEL_TASK=anthropic/claude-haiku-4-5
# LETTA_MODEL_CODING=anthropic/claude-sonnet-4-6
# LETTA_MODEL_HOMEASSISTANT=anthropic/claude-haiku-4-5

# ── GitHub Access ──────────────────────────────────────────────────
# Personal Access Token for GitHub operations.
# Used by: Task Agent (GitHub MCP server), Coding Agent (git clone, gh CLI)
# Create at: https://github.com/settings/tokens
# Required scopes: repo (for private repo access)
# GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── MCP Servers (optional - skip to disable) ───────────────────────

# Home Assistant MCP Server (ha-mcp)
# URL of your ha-mcp server (from HA add-on or external)
# e.g., http://homeassistant.local:8123/api/mcp or your add-on URL
# HOMEASSISTANT_MCP_URL=http://homeassistant.local:8123/api/mcp
# Long-lived access token from Home Assistant
# HOMEASSISTANT_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# Document Store (Filesystem MCP)
# Host path to the document store directory, mounted into the Letta container at /documents.
# This should point to the same directory your SilverBullet instance serves (e.g., ./space).
# Defaults to ./space if not set.
# DOCUMENT_STORE_PATH=./space

# ── Coding Sandbox Service ─────────────────────────────────────────
# URL where the coding sandbox service is running.
# In Docker Compose this is set automatically to http://coding-sandbox:3002
# SANDBOX_SERVICE_URL=http://localhost:3002

# Timeout for coding tasks in milliseconds (default: 10 minutes)
# TASK_TIMEOUT_MS=600000

# Commit co-authorship (optional)
# If set, the sandbox includes "Co-authored-by" in all git commits.
# This credits you alongside the bot for commits it creates.
# Your email must match your GitHub account for attribution to work.
GIT_COAUTHOR_NAME=
GIT_COAUTHOR_EMAIL=

# ── Discord Bot ────────────────────────────────────────────────────
# From Discord Developer Portal → Your App → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# From Discord Developer Portal → Your App → General Information
# Note: APP_ID / PUBLIC_KEY are not used at runtime by the bot code.
# Kept here for reference if you set up Discord HTTP interactions.
DISCORD_APPLICATION_ID=your_discord_application_id_here
DISCORD_PUBLIC_KEY=your_discord_public_key_here

# Your Personal Assistant agent ID (from running create_all.py)
LETTA_AGENT_ID=agent-xxxx-xxxx-xxxx-xxxx

# If true, includes a prefix on every message sent to the agent
# with info about the Discord user who sent the message (recommended)
LETTA_USE_SENDER_PREFIX=true
# Number of recent messages to include as context (0 to disable, default 5)
LETTA_CONTEXT_MESSAGE_COUNT=10
# Enable fetching full thread context when message is in a thread
LETTA_THREAD_CONTEXT_ENABLED=true
# Maximum number of messages to fetch from a thread (default 50, 0 for unlimited)
LETTA_THREAD_MESSAGE_LIMIT=50

# Set this if you want the bot to only listen to messages in a specific channel
# DISCORD_CHANNEL_ID=your_discord_channel_id
# Set this if you want the bot to only respond in a specific channel
# (agent sees all messages but only replies here)
# DISCORD_RESPONSE_CHANNEL_ID=your_discord_response_channel_id

# Response behavior
RESPOND_TO_DMS=true
RESPOND_TO_MENTIONS=true
RESPOND_TO_BOTS=false
RESPOND_TO_GENERIC=false
# If true, will send errors as messages in Discord
SURFACE_ERRORS=false
# If true, bot will reply in threads (creates new thread if needed)
REPLY_IN_THREADS=false

# Image Handling
# If true, image attachments will be forwarded to the agent
# Images over 5MB are skipped. Requires a multi-modal capable model.
ENABLE_IMAGE_HANDLING=false

# Voice Message Transcription
# If true, voice messages will be transcribed using OpenAI and sent as text
# Requires: OPENAI_API_KEY (set above) and ffmpeg installed on system
ENABLE_VOICE_TRANSCRIPTION=false
# Optional: Override the transcription model (default: gpt-4o-mini-transcribe)
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Per-Thread Conversations
# If true, each Discord thread gets its own Letta conversation
# Messages in threads are isolated; memory blocks are shared across conversations
ENABLE_THREAD_CONVERSATIONS=false
# File path to persist thread-to-conversation mappings (survives restarts)
# For Railway: mount a volume and set to /app/data/thread-conversations.json
# THREAD_CONVERSATIONS_FILE=./thread-conversations.json
# If true, bot responds to all messages in thread conversations without requiring mention
THREAD_CONVERSATIONS_RESPOND_WITHOUT_MENTION=false

# User-specific memory blocks
# If true, the bot will dynamically attach user-specific memory blocks
# for each Discord user mentioned in a message (including the sender).
# Blocks are attached before sending, then detached after the response.
ENABLE_USER_BLOCKS=false
# Optional: Override the label prefix for user blocks
# Default: /<agent_id>/discord/users/<user_id>
# USER_BLOCK_LABEL_PREFIX=/my-custom-prefix/users/
# Interval in minutes to run cleanup sweep for orphaned user blocks (default: 60)
USER_BLOCKS_CLEANUP_INTERVAL_MINUTES=60

# Message Batching (accumulate messages before sending to agent)
MESSAGE_BATCH_ENABLED=false
# Maximum number of messages to batch before auto-draining
MESSAGE_BATCH_SIZE=10
# Milliseconds to wait before auto-draining batch (default: 30 seconds)
MESSAGE_BATCH_TIMEOUT_MS=30000

# Notification block checker — polls a shared block for worker results (zero inference cost)
# Set to the block ID of the "notifications" block created by agents/create_all.py
# NOTIFICATIONS_BLOCK_ID=block-xxxxxxxx
# How often to check the notifications block (in minutes, default: 5)
NOTIFICATION_CHECK_INTERVAL_MINUTES=5

# Reflective heartbeat — periodically wakes the PA to think proactively
HEARTBEAT_ENABLED=false
HEARTBEAT_MIN_INTERVAL_MINUTES=20
HEARTBEAT_MAX_INTERVAL_MINUTES=60

# Bot server port
PORT=3001
